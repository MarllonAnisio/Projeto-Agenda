<%- include('includes/head.ejs') %>
<%- include('includes/nav.ejs') %>

<div class="container my-5">
    <div class="row justify-content-center">
        <div class="col-lg-6 col-md-8">
            
            <div class="text-center mb-4">
                <h1>Cadastro</h1>
                <p class="lead">Faça seu cadastro para acessar sua agenda.</p>
            </div>

            <div class="card shadow-sm">
                <div class="card-body p-4">
                    <h4 class="mb-4">Seus Dados</h4>
                    <%- include('includes/messages.ejs') %>
                    <form action="/cadastro/registrar" method="POST">
                        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                        <div class="mb-3">
                            <label for="nameInput" class="form-label">Nome</label>
                            <input type="text" class="form-control" id="nameInput" name="nome" required>
                        </div>
                        
                        <div class="mb-3">
                            <label for="lastNameInput" class="form-label">Sobrenome</label>
                            <input type="text" class="form-control" id="lastNameInput" name="sobrenome" required>
                        </div>
                        
                        <div class="mb-3">
                            <label for="emailInput" class="form-label">E-mail</label>
                            <input type="email" class="form-control" id="emailInput" name="email" required>
                        </div>
                        
                        <div class="mb-3">
                            <label for="passwordInput" class="form-label">Senha</label>
                            <input type="password" class="form-control" id="passwordInput" name="senha" required>
                        </div>
                        
                        <button type="submit" class="btn btn-primary w-100 mt-2">Cadastrar</button>
                    </form>
                </div>
            </div>

        </div>
    </div>
</div> <%- include('includes/footer.ejs') %>