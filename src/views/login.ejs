<%- include('includes/head.ejs') %>
  <%- include('includes/nav.ejs') %>

    <div class="container my-5">
      <div class="row justify-content-center">
        <div class="col-lg-5 col-md-7">

          <div class="text-center mb-4">
            <h1>Login</h1>
            <p class="lead">Faça login para acessar sua agenda.</p>
          </div>

          <div class="card shadow-sm">
            <div class="card-body p-4">
              <h4 class="mb-4 text-center">Entrar</h4>
              
              <%console.log("antes de incluir mensagens")%>
              <%- include('includes/messages.ejs') %>
              <%console.log("passou de mensagens")%>
              
              <form action="/login/login" method="POST">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                <div class="mb-3">
                  <label for="emailLogin" class="form-label">E-mail</label>
                  <input type="email" class="form-control" id="emailLogin" name="email" required>
                </div>

                <div class="mb-3">
                  <label for="senhaLogin" class="form-label">Senha</label>
                  <input type="password" class="form-control" id="senhaLogin" name="senha" required>
                </div>

                <div class="mb-3 form-check">
                  <input type="checkbox" class="form-check-input" id="lembrarMim" name="lembrar">
                  <label class="form-check-label" for="lembrarMim">Lembrar de mim</label>
                </div>

                <button type="submit" class="btn btn-primary w-100 mt-2">Entrar</button>
              </form>
            </div>
          </div>

        </div>
      </div>
    </div>
    <%- include('includes/footer.ejs') %>